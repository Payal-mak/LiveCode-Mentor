{
  "name": "livecode-mentor",
  "displayName": "LiveCode Mentor",
  "description": "AI-powered coding tutor for beginners",
  "version": "0.0.1",
  "publisher":"payal-mak",
  "icon": "media/icon.svg"
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "AI", "Programming Languages", "Education"
  ],
  "keywords": ["ai", "tutor", "code explanation", "live coding", "mentor"],
  "repository": {
    "type": "git",
    "url": "https://github.com/Payal-mak/LiveCode-Mentor.git"
  },
  "homepage": "https://github.com/Payal-mak/LiveCode-Mentor#readme",
  "bugs": {
    "url": "https://github.com/Payal-mak/LiveCode-Mentor/issues"
  },
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "livecode-mentor",
          "title": "LiveCode Mentor",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "livecode-mentor": [
        {
          "type": "webview",
          "id": "livecodeMentor",
          "name": "LiveCode Mentor"
        }
      ]
    },
    "commands": [
      {
        "command": "livecode-mentor.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "livecode-mentor.generateFlow",
        "title": "Generate Flow"
      },
      {
        "command": "livecode-mentor.checkFix",
        "title": "Check Fix"
      },
      {
        "command": "livecode-mentor.generateTrace",
        "title": "Generate Trace"
      },
      {
        "command": "livecode-mentor.setMode",
        "title": "Set Mode"
      },
      {
        "command": "livecode-mentor.explainLine",
        "title": "LiveCode Mentor: Explain This Line"
      },
      {
        "command": "livecode-mentor.reanalyze",
        "title": "Reanalyze"
        }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "livecode-mentor.explainLine",
          "group": "livecode",
          "when": "editorTextFocus"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "axios": "^1.13.6"
  }
}
